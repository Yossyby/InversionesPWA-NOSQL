NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Supabase (backend canonical names)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Supabase (accepted aliases for compatibility)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# JWT (required by backend auth middleware)
JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
JWT_EXPIRES_IN=24h

# Development auth bypass (local only)
# AUTH_BYPASS=true
# AUTH_BYPASS_USER_ID=dev-user
# AUTH_BYPASS_EMAIL=dev@local
# AUTH_BYPASS_ROLE=trader

# Optional direct PostgreSQL connection (for SQL migration tools)
SUPABASE_CONNECTION_STRING=postgresql://postgres.YOUR_PROJECT_ID:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# MongoDB (optional)
MONGODB_URI=

# Logging and tracing
LOG_LEVEL=info
TRACE_ENABLED=false

# Broker: Interactive Brokers (optional)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=

# Broker: Alpaca (optional)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# Timeouts (optional)
MARKET_DATA_TIMEOUT_MS=2000
BROKER_TIMEOUT_MS=5000
CLAUDE_TIMEOUT_MS=8000

# Watchlist: comma-separated default symbols shown when a user has no saved items
DEFAULT_WATCHLIST_SYMBOLS=SPY,QQQ,AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,AMD,JPM,COIN

# TEAM-05: SEC EDGAR scraper identity (required for 13F filings)
EDGAR_USER_AGENT=TurboPapus/1.0 (contact@turbopapus.com)

# TEAM-05: Gemini AI copilot (required for institutional chat)
GEMINI_API_KEY=<obtener del proyecto TEAM-05>

# Tradier — opcional. Cuando se configura, reemplaza Yahoo Finance para option chains y OHLC.
# Registrar en: https://developer.tradier.com/ (sandbox gratuito disponible)
# Sin esta key: el sistema usa Yahoo Finance como fallback automático — sin cambios de código.
TRADIER_API_KEY=
TRADIER_BASE_URL=https://sandbox.tradier.com/v1
# Producción: TRADIER_BASE_URL=https://api.tradier.com/v1

# MarketData.app — opción gratuita para cadena de opciones con IV y Greeks completos.
# Registro gratuito (sin tarjeta): https://www.marketdata.app/
# Una vez registrado, copia tu API Token del dashboard y pégalo aquí:
MARKETDATA_API_TOKEN=
